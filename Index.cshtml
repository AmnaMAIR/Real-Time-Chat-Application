                const unreadSection = document.getElementById("statusUpdatesList");
                const viewedSection = document.getElementById("viewedStatusSection");
                const viewedList = document.getElementById("viewedStatusList");
                if(!unreadSection) return;

                unreadSection.innerHTML = '<div class="status-section-label">Recent updates</div>';
                viewedList.innerHTML = "";
                let hasViewed = false;

                statusData.forEach((s, i) => {
                    const markup = `
                        <div class="status-contact-row" onclick="openStatusViewer(${i})">
                            <div class="status-unread-ring ${s.viewed?'viewed':''}">
                                <img src="${s.img}" onerror="this.src='https://ui-avatars.com/api/?name=${encodeURIComponent(s.name)}&background=075E54&color=fff'">
