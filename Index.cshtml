            // =============================================
            // 🎙️ VOICE MESSAGES
            // =============================================
            function toggleVoiceMessageRecordingSession() {
                const textInput = document.getElementById("chatInputFieldElement");
                const dock = document.getElementById("recordingActiveStateDockNode");
                const glyph = document.getElementById("footerActionGlyphIcon");
                const timer = document.getElementById("recordingLiveTimerNode");

                if(!isRecordingModeActive) {
                    isRecordingModeActive = true;
                    textInput.style.display = "none"; dock.style.display = "flex";
                    glyph.className = "bi bi-stop-fill";
                    recordingSecondsCounter = 0; timer.innerText = "00:00";
                    recordingTimerIntervalObject = setInterval(() => {
                        recordingSecondsCounter++;
                        timer.innerText = `${String(Math.floor(recordingSecondsCounter/60)).padStart(2,'0')}:${String(recordingSecondsCounter%60).padStart(2,'0')}`;
                    }, 1000);
                } else {
                    isRecordingModeActive = false;
                    clearInterval(recordingTimerIntervalObject);
                    textInput.style.display = "block"; dock.style.display = "none";
                    glyph.className = "bi bi-mic-fill";

                    const dur = `${String(Math.floor(recordingSecondsCounter/60)).padStart(2,'0')}:${String(recordingSecondsCounter%60).padStart(2,'0')}`;
                    const pid = "audio_" + Date.now();
                    const audioMarkup = `
                        <div class="wa-audio-player-node-container" id="${pid}">
                            <i class="bi bi-play-fill wa-audio-play-trigger-btn" onclick="executeAudioHardwareSynthesizerPipeline('${pid}')"></i>
                            <div class="wa-audio-wave-bar-track"><div class="wa-audio-wave-fill-progress"></div></div>
                            <small style="font-size:0.72rem;color:#888;">${dur}</small>
                        </div>`;
                    const stamp = now();
                    targetGlobalContactsArray[compiledActiveContactIndexId].stream.push({ text:audioMarkup, time:stamp, isMe:true, tickState:1, isStarred:false });
                    rebuildCurrentChatHistoryCanvasWall();
                    triggerPostSendTickUpgrades();
                }
            }
            function executeAudioHardwareSynthesizerPipeline(pid) {
                const node = document.getElementById(pid);
                if(!node) return;
                const btn = node.querySelector('.wa-audio-play-trigger-btn');
                const fill = node.querySelector('.wa-audio-wave-fill-progress');
                if(btn.classList.contains('bi-play-fill')) {
                    btn.className = "bi bi-pause-fill wa-audio-play-trigger-btn";
                    fill.style.transition = "width 3s linear";
                    setTimeout(() => { fill.style.width = "100%"; }, 30);
                    try {
                        const AudioContext = window.AudioContext || window.webkitAudioContext;
                        audioContextEngineReference = new AudioContext();
                        const osc = audioContextEngineReference.createOscillator();
                        const gain = audioContextEngineReference.createGain();
                        osc.type = 'sine'; osc.frequency.setValueAtTime(300, audioContextEngineReference.currentTime);
                        gain.gain.setValueAtTime(0.1, audioContextEngineReference.currentTime);
                        osc.connect(gain); gain.connect(audioContextEngineReference.destination);
                        osc.start(); osc.stop(audioContextEngineReference.currentTime + 3);
                    } catch(e){}
                    setTimeout(() => {
                        btn.className = "bi bi-play-fill wa-audio-play-trigger-btn";
                        fill.style.transition = "none"; fill.style.width = "0%";
                        if(audioContextEngineReference) audioContextEngineReference.close();
                    }, 3200);
                } else {
                    btn.className = "bi bi-play-fill wa-audio-play-trigger-btn";
                    fill.style.transition = "none"; fill.style.width = "0%";
                    if(audioContextEngineReference) audioContextEngineReference.close();
                }
            }

            // =============================================
            // 📎 ATTACHMENTS
            // =============================================
            function commitUploadedAttachmentFileToStream(inputEl) {
                const file = inputEl.files[0];
                if(!file) return;
                const reader = new FileReader();
                const stamp = now();
                if(file.type.startsWith('image/')) {
                    reader.onload = e => {
                        const markup = `<img src="${e.target.result}" style="width:100%;max-height:160px;object-fit:cover;display:block;border-radius:4px;cursor:pointer;" onclick="window.open('${e.target.result}')">`;
                        targetGlobalContactsArray[compiledActiveContactIndexId].stream.push({ text:markup, time:stamp, isMe:true, tickState:1, isStarred:false });
                        rebuildCurrentChatHistoryCanvasWall();
                        triggerPostSendTickUpgrades();
                    };
                    reader.readAsDataURL(file);
                } else {
                    reader.onload = e => {
                        const markup = `<a href="${e.target.result}" download="${file.name}" style="display:block;background:#f0f2f5;border-radius:6px;padding:8px 10px;text-decoration:none;color:#111;">
                            <div style="display:flex;align-items:center;gap:8px;">
                                <i class="bi bi-file-earmark-text-fill" style="color:#075E54;font-size:1.4rem;"></i>
                                <div style="overflow:hidden;">
                                    <div style="font-size:0.8rem;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:120px;">${file.name}</div>
                                    <div style="font-size:0.68rem;color:#888;">Tap to open</div>
                                </div>
                                <i class="bi bi-download" style="color:#25D366;margin-left:auto;"></i>
                            </div>
                        </a>`;
                        targetGlobalContactsArray[compiledActiveContactIndexId].stream.push({ text:markup, time:stamp, isMe:true, tickState:1, isStarred:false });
                        rebuildCurrentChatHistoryCanvasWall();
                        triggerPostSendTickUpgrades();
                    };
                    reader.readAsDataURL(file);
                }
                inputEl.value = "";
            }
            function triggerPostSendTickUpgrades() {
                const stream = targetGlobalContactsArray[compiledActiveContactIndexId].stream;
                const ptr = stream.length - 1;
                setTimeout(()=>{ if(stream[ptr]) { stream[ptr].tickState=2; rebuildCurrentChatHistoryCanvasWall(); } }, 800);
                setTimeout(()=>{ if(stream[ptr]) { stream[ptr].tickState=3; rebuildCurrentChatHistoryCanvasWall(); } triggerControlledSingleResponse(); }, 1800);
            }

            // =============================================
            // 📷 CAMERA
            // =============================================
            function triggerHardwareCameraOverlay(open) {
                const overlay = document.getElementById("appHardwareCameraOverlayLayer");
                const video = document.getElementById("hardwareLiveVideoElement");
                if(open) {
                    overlay.style.display = "flex";
                    navigator.mediaDevices.getUserMedia({ video:true })
                        .then(stream => {
                            cameraStreamObjectReference = stream;
                            video.srcObject = stream;
                            video.style.display = "block";
                            document.getElementById("cameraAlternativeFallbackUILabel").style.display = "none";
                        }).catch(()=>{
                            video.style.display = "none";
                            document.getElementById("cameraAlternativeFallbackUILabel").style.display = "block";
                        });
                } else {
                    if(cameraStreamObjectReference) { cameraStreamObjectReference.getTracks().forEach(t=>t.stop()); cameraStreamObjectReference = null; }
                    overlay.style.display = "none";
                }
            }
            function commitHardwareCapturedPhotoPipeline() {
                const video = document.getElementById("hardwareLiveVideoElement");
                const canvas = document.getElementById("hardwareHiddenFrameCanvasAsset");
                canvas.width = 320; canvas.height = 240;
                const ctx = canvas.getContext('2d');
                let imgSrc;
                if(cameraStreamObjectReference && video.style.display!=="none") {
                    ctx.drawImage(video, 0, 0, canvas.width, canvas.height);
                    imgSrc = canvas.toDataURL('image/png');
                } else {
                    ctx.fillStyle = "#075E54"; ctx.fillRect(0,0,canvas.width,canvas.height);
                    ctx.fillStyle = "#fff"; ctx.font = "bold 14px Roboto"; ctx.fillText("📷 Captured!", 80, 120);
                    imgSrc = canvas.toDataURL('image/png');
                }
                const stamp = now();
                const markup = `<img src="${imgSrc}" style="width:100%;max-height:160px;object-fit:cover;display:block;border-radius:4px;cursor:pointer;" onclick="window.open('${imgSrc}')">`;
                targetGlobalContactsArray[compiledActiveContactIndexId].stream.push({ text:markup, time:stamp, isMe:true, tickState:1, isStarred:false });
                rebuildCurrentChatHistoryCanvasWall();
                triggerPostSendTickUpgrades();
                triggerHardwareCameraOverlay(false);
            }

            // =============================================
            // 👤 CONTACT INFO DRAWER
            // =============================================
            function launchContactMetadataInfoDrawer() {
                const c = targetGlobalContactsArray[compiledActiveContactIndexId];
                document.getElementById("targetLargeDrawerProfileTitleLabel").innerText = c.name;
                document.getElementById("targetLargeDrawerProfileAvatarPic").src = c.img;
                document.getElementById("targetLargeDrawerPhoneStringNode").innerText = c.phone;
                document.getElementById("targetDrawerAboutText").innerText = c.isGroup ? `${(c.members||[]).length+1} participants` : "Hey there! I am using WhatsApp.";
                document.getElementById("appContactProfileInfoDrawerWindow").classList.add("open");
                hideDrop('privateChatContextDropdown');
            }
            function dismissContactMetadataInfoDrawer() {
                document.getElementById("appContactProfileInfoDrawerWindow").classList.remove("open");
            }

            // =============================================
            // 🗑️ CLEAR CHAT
            // =============================================
            function executeClearChatHistoryEngine() {
                targetGlobalContactsArray[compiledActiveContactIndexId].stream = [];
                rebuildCurrentChatHistoryCanvasWall();
                hideDrop('privateChatContextDropdown');
                showToast("Chat cleared");
            }

            // =============================================
            // 📋 DROPDOWNS
            // =============================================
            function toggleMainDashboardDropdownMenu(event) {
                event.stopPropagation();
                const el = document.getElementById("mainDashboardContextDropdown");
                el.style.display = (el.style.display==="block") ? "none" : "block";
            }
            function togglePrivateDropdownMenu(event) {
                event.stopPropagation();
                const el = document.getElementById("privateChatContextDropdown");
                el.style.display = (el.style.display==="block") ? "none" : "block";
            }
            function hideDrop(id) {
                const el = document.getElementById(id);
                if(el) el.style.display = "none";
            }

            // =============================================
            // 🛠️ SETTINGS PANELS
            // =============================================
            function openNestedSettingsPanel(id) { const el=document.getElementById(id); if(el) el.style.display="flex"; }
            function closeNestedSettingsPanel(id) { const el=document.getElementById(id); if(el) el.style.display="none"; }
            function openSettingsViewPanel() { hideDrop('mainDashboardContextDropdown'); document.getElementById("submoduleSettingsViewDrawer").style.display="flex"; }

            // =============================================
            // 🌐 MISC SUBMODULES
            // =============================================
            function openNewBroadcastModal() { hideDrop('mainDashboardContextDropdown'); document.getElementById("submoduleNewBroadcastDrawer").style.display="flex"; }
            function launchWhatsAppWebSimulator() { hideDrop('mainDashboardContextDropdown'); document.getElementById("submoduleWhatsAppWebDrawer").style.display="flex"; }
            function closeGenericSubmoduleView(id) { const el=document.getElementById(id); if(el) el.style.display="none"; }

            // =============================================
            // 🍞 TOAST NOTIFICATION
            // =============================================
            let toastTimer = null;
            function showToast(msg) {
                const t = document.getElementById("waToast");
                t.innerText = msg; t.classList.add("show");
                if(toastTimer) clearTimeout(toastTimer);
                toastTimer = setTimeout(() => t.classList.remove("show"), 2500);
            }

            // =============================================
            // 🕐 UTILITY
            // =============================================
            function now() {
                return new Date().toLocaleTimeString([], { hour:'2-digit', minute:'2-digit', hour12:true }).toLowerCase();
            }

    </script>
</body>
</html>
