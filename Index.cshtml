            function postNewStatus() {
                const text = document.getElementById("statusTextInput").value.trim();
                const imgInput = document.getElementById("statusImageInput");
                if(!text && !imgInput.files.length) { showToast("Please write something or choose a photo"); return; }

                const stamp = new Date().toLocaleTimeString([], { hour:'2-digit', minute:'2-digit', hour12:true }).toLowerCase();

                const postStatus = (imgSrc) => {
                    statusData.unshift({
                        name:"You", img:"https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?w=100",
                        time:"just now", type: imgSrc ? "image" : "text",
                        content: imgSrc || text, viewed:false
                    });
                    document.getElementById("myStatusSubtext").innerText = `Updated ${stamp}`;
                    renderStatusTab();
                    closeStatusPostOverlay();
                    showToast("Status posted! ✅");
