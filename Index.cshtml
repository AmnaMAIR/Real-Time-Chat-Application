            function openStatusPostOverlay() {
                document.getElementById("statusPostOverlay").style.display = "flex";
                document.getElementById("statusTextInput").value = "";
                document.getElementById("statusImagePreview").style.display = "none";
                document.getElementById("statusImageInput").value = "";
