            // =============================================
            // 📞 CALLS
            // =============================================
            function renderCallLogs() {
                const target = document.getElementById("callLogListTarget");
                if(!target) return;
                target.innerHTML = "";
                callLogData.forEach((call, i) => {
                    const icon = call.type==='missed' ? 'bi-telephone-x-fill text-danger' :
                        call.type==='incoming' ? 'bi-telephone-inbound-fill text-success' : 'bi-telephone-outbound-fill text-primary';
                    const callIcon = call.callType==='video' ? 'bi-camera-video-fill' : 'bi-telephone-fill';
                    target.insertAdjacentHTML('beforeend', `
                        <div class="call-log-row">
                            <div class="wa-avatar-circle"><img src="${call.img}"></div>
                            <div class="call-info">
                                <div class="call-name ${call.missed?'text-danger':''}">${call.name}</div>
                                <div class="call-detail ${call.missed?'missed':''}">
                                    <i class="bi ${icon}" style="margin-right:4px;font-size:0.75rem;"></i>
                                    ${call.type.charAt(0).toUpperCase()+call.type.slice(1)} · ${call.time}
                                </div>
                            </div>
                            <i class="bi ${callIcon} call-icon-btn" onclick="startCallFromLog(${i})"></i>
                        </div>`);
                });
            }

            function startCallFromLog(idx) {
                const call = callLogData[idx];
                const contact = targetGlobalContactsArray.find(c=>c.name===call.name);
                if(contact) {
                    const ci = targetGlobalContactsArray.indexOf(contact);
                    compiledActiveContactIndexId = ci;
                    triggerOutgoingCallSystem(call.callType==='video'?'Video Call':'Voice Call');
                }
            }

            function makeCallFromContacts() { showToast("Select a contact to call"); }

            function clearCallLogs() {
                callLogData.length = 0;
                renderCallLogs();
                showToast("Call history cleared");
            }

            function triggerOutgoingCallSystem(callTypeString) {
                const contact = targetGlobalContactsArray[compiledActiveContactIndexId];
                const overlay = document.getElementById("appActiveCallOverlayScreen");
                const durationLabel = document.getElementById("callDurationTickerString");

                document.getElementById("callScreenTypeNameLabel").innerText = `WhatsApp ${callTypeString}`;
                document.getElementById("callScreenProfileNameTarget").innerText = contact.name;
                document.getElementById("callScreenProfilePicTarget").src = contact.img;

                overlay.style.display = "flex";
                callSecondsCounter = 0;
                durationLabel.innerText = "Ringing...";
                durationLabel.classList.add("blink-animation");

                const remoteVideo = document.getElementById("appCallRemoteVideoTrack");
                const localPip = document.getElementById("appCallLocalPipFrame");
                remoteVideo.style.display = "none"; localPip.style.display = "none";
                document.getElementById("callScreenAvatarCentralBox").style.display = "block";

                if(callTypeString === "Video Call") {
                    navigator.mediaDevices.getUserMedia({ video:true, audio:true })
                        .then(stream => {
                            callingStreamObjectReference = stream;
                            document.getElementById("callScreenAvatarCentralBox").style.display = "none";
                            remoteVideo.style.display = "block"; localPip.style.display = "block";
                            document.getElementById("appCallLocalVideoTrack").srcObject = stream;
                            remoteVideo.poster = contact.img;
                        }).catch(() => {});
                }

                // Add to call log
                callLogData.unshift({ name:contact.name, img:contact.img, type:'outgoing', callType: callTypeString==='Video Call'?'video':'voice', time:'Just now', missed:false });

                activeCallTimerIntervalObject = setInterval(() => {
                    callSecondsCounter++;
                    if(callSecondsCounter > 2) {
                        durationLabel.classList.remove("blink-animation");
                        let dur = callSecondsCounter - 2;
                        durationLabel.innerText = `${String(Math.floor(dur/60)).padStart(2,'0')}:${String(dur%60).padStart(2,'0')}`;
                    }
                }, 1000);
            }

            function terminateActiveCallSessionPipeline() {
                if(activeCallTimerIntervalObject) { clearInterval(activeCallTimerIntervalObject); activeCallTimerIntervalObject = null; }
                if(callingStreamObjectReference) { callingStreamObjectReference.getTracks().forEach(t=>t.stop()); callingStreamObjectReference = null; }
                document.getElementById("appActiveCallOverlayScreen").style.display = "none";
            }

            function toggleCallMute() {
                callMuted = !callMuted;
                const btn = document.getElementById("callMuteBtn");
                btn.innerHTML = callMuted ? `<i class="bi bi-mic-mute-fill"></i>` : `<i class="bi bi-mic-fill"></i>`;
                btn.style.background = callMuted ? "rgba(255,255,255,0.5)" : "rgba(255,255,255,0.2)";
                showToast(callMuted ? "Muted" : "Unmuted");
            }

