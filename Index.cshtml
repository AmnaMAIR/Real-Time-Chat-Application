        function toggleVoiceMessageRecordingSession() {
            const textInput = document.getElementById("chatInputFieldElement");
            const dockNode = document.getElementById("recordingActiveStateDockNode");
            const glyph = document.getElementById("footerActionGlyphIcon");
            const timerLabel = document.getElementById("recordingLiveTimerNode");

            if (!isRecordingModeActive) {
                isRecordingModeActive = true;
                textInput.style.display = "none";
                dockNode.style.display = "flex";
                glyph.className = "bi bi-stop-fill text-white";
                
                recordingSecondsCounter = 0;
                timerLabel.innerText = "Recording... 00:00";
                recordingTimerIntervalObject = setInterval(() => {
                    recordingSecondsCounter++;
                    let m = String(Math.floor(recordingSecondsCounter / 60)).padStart(2, '0');
                    let s = String(recordingSecondsCounter % 60).padStart(2, '0');
                    timerLabel.innerText = `Recording... ${m}:${s}`;
                }, 1000);
            } else {
                isRecordingModeActive = false;
                clearInterval(recordingTimerIntervalObject);
                textInput.style.display = "block";
                dockNode.style.display = "none";
                glyph.className = "bi bi-mic-fill text-white";

                let m = String(Math.floor(recordingSecondsCounter / 60)).padStart(2, '0');
                let s = String(recordingSecondsCounter % 60).padStart(2, '0');
                
                const uniquePlayerIdHash = "audio_" + new Date().getTime();
                const waveAudioMarkup = `
                    <div class="wa-audio-player-node-container" id="${uniquePlayerIdHash}">
                        <i class="bi bi-play-fill wa-audio-play-trigger-btn" onclick="executeAudioHardwareSynthesizerPipeline('${uniquePlayerIdHash}')"></i>
                        <div class="wa-audio-wave-bar-track">
                            <div class="wa-audio-wave-fill-progress"></div>
                        </div>
                        <small class="text-muted small">${m}:${s}</small>
                    </div>`;

                const stamp = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', hour12: true }).toLowerCase();
                targetGlobalContactsArray[compiledActiveContactIndexId].stream.push({ text: waveAudioMarkup, time: stamp, isMe: true, tickState: 1, isStarred: false });
                rebuildCurrentChatHistoryCanvasWall();
                triggerPostSendTickUpgrades();
            }
        }

        function executeAudioHardwareSynthesizerPipeline(playerIdKeyString) {
            const basePlayerNode = document.getElementById(playerIdKeyString);
            if(!basePlayerNode) return;

            const playBtn = basePlayerNode.querySelector('.wa-audio-play-trigger-btn');
            const progressFill = basePlayerNode.querySelector('.wa-audio-wave-fill-progress');

            if(playBtn.classList.contains('bi-play-fill')) {
                playBtn.className = "bi bi-pause-fill wa-audio-play-trigger-btn text-danger";
                progressFill.style.width = "100%";
                progressFill.style.transition = "width 3.5s linear";

                try {
                    const AudioContext = window.AudioContext || window.webkitAudioContext;
                    audioContextEngineReference = new AudioContext();
                    const oscillatorNode = audioContextEngineReference.createOscillator();
                    const gainNode = audioContextEngineReference.createGain();
                    
                    oscillatorNode.type = 'sine'; oscillatorNode.frequency.setValueAtTime(320, audioContextEngineReference.currentTime); 
                    gainNode.gain.setValueAtTime(0.12, audioContextEngineReference.currentTime); 
                    
                    oscillatorNode.connect(gainNode); gainNode.connect(audioContextEngineReference.destination);
                    oscillatorNode.start(); oscillatorNode.stop(audioContextEngineReference.currentTime + 3.2);
                } catch(e) { console.log(e); }

                setTimeout(() => {
                    playBtn.className = "bi bi-play-fill wa-audio-play-trigger-btn";
                    progressFill.style.transition = "none"; progressFill.style.width = "0%";
                    if(audioContextEngineReference) audioContextEngineReference.close();
                }, 3500);
            } else {
                playBtn.className = "bi bi-play-fill wa-audio-play-trigger-btn";
                progressFill.style.transition = "none"; progressFill.style.width = "0%";
                if(audioContextEngineReference) audioContextEngineReference.close();
            }
        }

        // ==========================================
        // 📷 REAL HARDWARE CAMERA ENGINE 
        // ==========================================
        function triggerHardwareCameraOverlay(openViewfinderFlag) {
            const overlay = document.getElementById("appHardwareCameraOverlayLayer");
            const videoElement = document.getElementById("hardwareLiveVideoElement");

            if (openViewfinderFlag) {
                overlay.style.display = "flex";
                navigator.mediaDevices.getUserMedia({ video: true })
                    .then(stream => {
                        cameraStreamObjectReference = stream;
                        videoElement.style.display = "block";
                        videoElement.srcObject = stream;
                    }).catch(err => {
                        console.log("Using dynamic mock frame layer layout system configuration context:", err);
                        videoElement.style.display = "none";
                    });
            } else {
                terminateLiveCameraHardwareStream(); 
                overlay.style.display = "none";
            }
        }

        function terminateLiveCameraHardwareStream() {
            if (cameraStreamObjectReference) {
                cameraStreamObjectReference.getTracks().forEach(track => track.stop());
                cameraStreamObjectReference = null;
            }
        }

        function commitHardwareCapturedPhotoPipeline() {
            const videoElement = document.getElementById("hardwareLiveVideoElement");
            const canvasElement = document.getElementById("hardwareHiddenFrameCanvasAsset");
            let imageSourcePath = "https://images.unsplash.com/photo-1542831371-29b0f74f9713?w=300"; 

            const ctx = canvasElement.getContext('2d');
            canvasElement.width = 320;
            canvasElement.height = 240;

            if (cameraStreamObjectReference && videoElement.style.display !== "none") {
                ctx.drawImage(videoElement, 0, 0, canvasElement.width, canvasElement.height);
                imageSourcePath = canvasElement.toDataURL('image/png');
            } else {
                ctx.fillStyle = "#075E54";
                ctx.fillRect(0, 0, canvasElement.width, canvasElement.height);
                ctx.fillStyle = "#ffffff";
                ctx.font = "bold 14px Roboto";
                ctx.fillText("📷 Captured Photo Asset Frame", 30, 110);
                ctx.font = "11px Roboto";
                ctx.fillStyle = "rgba(255,255,255,0.7)";
                ctx.fillText("Simulated Media Stream Framework", 30, 135);
                imageSourcePath = canvasElement.toDataURL('image/png');
            }

            const stamp = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', hour12: true }).toLowerCase();
            const compiledPhotoMarkup = `<img src="${imageSourcePath}" style="width:100%; max-height:160px; object-fit:cover; display:block; border-radius:4px; cursor:pointer;" class="mt-1" onclick="window.open('${imageSourcePath}')">`;
            
            targetGlobalContactsArray[compiledActiveContactIndexId].stream.push({ text: compiledPhotoMarkup, time: stamp, isMe: true, tickState: 1, isStarred: false });
            rebuildCurrentChatHistoryCanvasWall();
            triggerPostSendTickUpgrades();
            triggerHardwareCameraOverlay(false);
        }

        // ==========================================
        // 📞 REAL DYNAMIC VIDEO/VOICE CALLS 
        // ==========================================
        function triggerOutgoingCallSystem(callTypeString) {
            const currentContact = targetGlobalContactsArray[compiledActiveContactIndexId];
            const callOverlay = document.getElementById("appActiveCallOverlayScreen");
            const durationLabel = document.getElementById("callDurationTickerString");
            
            const remoteVideo = document.getElementById("appCallRemoteVideoTrack");
            const localPip = document.getElementById("appCallLocalPipFrame");
            const localVideo = document.getElementById("appCallLocalVideoTrack");
            const avatarBox = document.getElementById("callScreenAvatarCentralBox");

            document.getElementById("callScreenTypeNameLabel").innerText = `WhatsApp ${callTypeString}`;
            document.getElementById("callScreenProfileNameTarget").innerText = currentContact.name;
            document.getElementById("callScreenProfilePicTarget").src = currentContact.img;
            
            callOverlay.style.display = "flex";
            callSecondsCounter = 0;
            durationLabel.innerText = "Ringing...";
            durationLabel.classList.add("blink-animation");

            remoteVideo.style.display = "none";
            localPip.style.display = "none";
            avatarBox.style.display = "block";

            if(callTypeString === "Video Call") {
                navigator.mediaDevices.getUserMedia({ video: true, audio: true })
                    .then(stream => {
                        callingStreamObjectReference = stream;
                        avatarBox.style.display = "none";
                        remoteVideo.style.display = "block";
                        localPip.style.display = "block";
                        
                        localVideo.srcObject = stream;
                        remoteVideo.poster = currentContact.img; 
                    }).catch(err => {
                        console.log("Video track stream failure mapping:", err);
                    });
            }

            activeCallTimerIntervalObject = setInterval(() => {
                callSecondsCounter++;
                if (callSecondsCounter > 2) {
                    durationLabel.classList.remove("blink-animation");
                    let activeCallDuration = callSecondsCounter - 2;
                    let m = String(Math.floor(activeCallDuration / 60)).padStart(2, '0');
                    let s = String(activeCallDuration % 60).padStart(2, '0');
                    durationLabel.innerText = `${m}:${s}`;
                }
            }, 1000);
        }

        function terminateActiveCallSessionPipeline() {
            if(activeCallTimerIntervalObject) { clearInterval(activeCallTimerIntervalObject); activeCallTimerIntervalObject = null; }
            if (callingStreamObjectReference) {
                callingStreamObjectReference.getTracks().forEach(track => track.stop());
                callingStreamObjectReference = null;
            }
            document.getElementById("appActiveCallOverlayScreen").style.display = "none";
        }
     

