        function commitUploadedAttachmentFileToStream(inputSourceElement) {
            const targetingFileObject = inputSourceElement.files[0];
            if(!targetingFileObject) return;

            const readerInstance = new FileReader();
            const stamp = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', hour12: true }).toLowerCase();

            if (targetingFileObject.type.startsWith('image/')) {
                readerInstance.onload = function(e) {
                    const inlinePhotoMarkup = `<img src="${e.target.result}" style="width:100%; max-height:160px; object-fit:cover; display:block; border-radius:4px; cursor:pointer;" class="mt-1" onclick="window.open('${e.target.result}')">`;
                    targetGlobalContactsArray[compiledActiveContactIndexId].stream.push({ text: inlinePhotoMarkup, time: stamp, isMe: true, tickState: 1, isStarred: false });
                    rebuildCurrentChatHistoryCanvasWall();
                    triggerPostSendTickUpgrades();
                };
                readerInstance.readAsDataURL(targetingFileObject);
            } else {
                readerInstance.onload = function(e) {
                    const encodedDataUrlBlobString = e.target.result;
                    const docTemplateMarkup = `
                        <a href="${encodedDataUrlBlobString}" download="${targetingFileObject.name}" class="text-decoration-none d-block card bg-light border p-2 text-dark mt-1" style="font-size:0.82rem; cursor:pointer;">
                            <div class="d-flex align-items-center gap-2">
                                <i class="bi bi-file-earmark-text-fill text-primary fs-3"></i>
                                <div style="overflow:hidden; text-overflow:ellipsis; white-space:nowrap; max-width:120px;">
                                    <strong class="d-block text-truncate" style="font-size:0.8rem;">${targetingFileObject.name}</strong>
                                    <small class="text-muted" style="font-size:0.68rem;">Click to download/open</small>
                                </div>
                                <i class="bi bi-download ms-auto text-success fs-5"></i>
                            </div>
                        </a>`;
                    
                    targetGlobalContactsArray[compiledActiveContactIndexId].stream.push({ text: docTemplateMarkup, time: stamp, isMe: true, tickState: 1, isStarred: false });
                    rebuildCurrentChatHistoryCanvasWall();
                    triggerPostSendTickUpgrades();
                };
                readerInstance.readAsDataURL(targetingFileObject);
            }
            inputSourceElement.value = "";
        }

        function triggerPostSendTickUpgrades() {
            const streamRef = targetGlobalContactsArray[compiledActiveContactIndexId].stream;
            const targetPointer = streamRef.length - 1;
            setTimeout(() => { if(streamRef[targetPointer]) { streamRef[targetPointer].tickState = 2; rebuildCurrentChatHistoryCanvasWall(); } }, 800);
            setTimeout(() => { 
                if(streamRef[targetPointer]) { streamRef[targetPointer].tickState = 3; rebuildCurrentChatHistoryCanvasWall(); } 
                triggerControlledSingleResponse();
            }, 1800);
        }

        // ==========================================
