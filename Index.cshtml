                    { text:"System: Group created", time:"Mon", isMe:true, tickState:3, isStarred:false, sender:"You" },
                    { text:"Evaluation tomorrow at 9am everyone!", time:"Yesterday", isMe:false, tickState:0, isStarred:false, sender:"Sara Naz" },
                    { text:"Evaluation tomorrow at 9am ⚠️", time:"Yesterday", isMe:false, tickState:0, isStarred:false, sender:"Zeeshan Bro" }
                ]},
                { id:"p4", name:"Usman Dev", img:"https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?w=100", phone:"+92 311 2223334", phrase:"Code review done ✅", time:"Mon", unreadCount:0, isGroup:false, stream:[
                    { text:"Code review kar lena please.", time:"Mon", isMe:true, tickState:3, isStarred:false },
                    { text:"Code review done ✅", time:"Mon", isMe:false, tickState:0, isStarred:false }
                ]}
            ];

            // Statuses data
            const statusData = [
                { name:"Sara Naz", img:"https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=100", time:"10 min ago", type:"text", content:"Feeling great today! 😊✨", viewed:false },
                { name:"Zeeshan Bro", img:"https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=100", time:"30 min ago", type:"text", content:"Working on new project 💻🔥", viewed:false },
                { name:"Usman Dev", img:"https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?w=100", time:"1 hr ago", type:"text", content:"Code compile hua finally! 🎉", viewed:true }
            ];

            // Call logs
            const callLogData = [
                { name:"Sara Naz", img:"https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=100", type:"incoming", callType:"voice", time:"Today, 12:10 pm", missed:false },
                { name:"Zeeshan Bro", img:"https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=100", type:"missed", callType:"voice", time:"Today, 10:30 am", missed:true },
                { name:"CS Lab Group 👥", img:"https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=100", type:"outgoing", callType:"video", time:"Yesterday, 3:00 pm", missed:false },
                { name:"Ayesha", img:"https://images.unsplash.com/photo-1534528741775-53994a69daeb?w=100", type:"incoming", callType:"video", time:"Mon, 6:00 pm", missed:false }
            ];

            // State vars
            let compiledActiveContactIndexId = 0;
            let isChatWindowOpen = false;
            let isRecordingModeActive = false;
            let recordingTimerIntervalObject = null;
            let recordingSecondsCounter = 0;
            let activeCallTimerIntervalObject = null;
            let callSecondsCounter = 0;
            let typingSimulatorTimeoutObject = null;
            let replySimulatorTimeoutObject = null;
            let audioContextEngineReference = null;
            let cameraStreamObjectReference = null;
            let callingStreamObjectReference = null;
            let activeTrackedMessageTargetIndex = null;
            let callMuted = false;
            let currentStatusViewerIndex = 0;
            let statusViewerTimer = null;
            let currentStatusViewingContact = null;

            // Real-time sync using BroadcastChannel
            let bc = null;
            try { bc = new BroadcastChannel('wa_clone_rt'); } catch(e){}

            // =============================================
            // 🚀 INIT
            // =============================================
            window.addEventListener('load', () => {
                switchTab('CHATS');
                renderCallLogs();
                renderStatusTab();
                renderEmojiPanel();
                if(bc) {
                    bc.onmessage = (e) => {
                        if(e.data && e.data.type === 'new_message') {
                            const { contactId, msg } = e.data;
                            const contact = targetGlobalContactsArray.find(c => c.id === contactId);
                            if(contact) {
                                contact.stream.push(msg);
                                if(isChatWindowOpen && targetGlobalContactsArray[compiledActiveContactIndexId].id === contactId) {
                                    rebuildCurrentChatHistoryCanvasWall();
                                } else {
                                    contact.unreadCount = (contact.unreadCount || 0) + 1;
                                    contact.time = msg.time;
                                    contact.phrase = msg.text.replace(/<[^>]+>/g,'').substring(0,40);
                                    renderMobileChatsListEngine(targetGlobalContactsArray);
                                }
                            }
                        }
                    };
                }
            });

            document.addEventListener('click', (e) => {
                document.querySelectorAll('.wa-private-dropdown').forEach(d => {
                    if(!d.contains(e.target)) d.style.display = 'none';
                });
            });

            // =============================================
            // 📋 TAB SWITCHING — FULLY WORKING
            // =============================================
            function switchTab(tabName) {
                document.querySelectorAll('.wa-tab-view-panel').forEach(p => p.classList.remove('active-view'));
                document.querySelectorAll('.wa-tab-item').forEach(t => t.classList.remove('active'));

                const panel = document.getElementById('view-panel-' + tabName);
                const tab = document.getElementById('tab' + tabName.charAt(0) + tabName.slice(1).toLowerCase());
                if(panel) panel.classList.add('active-view');
                if(tab) tab.classList.add('active');

                if(tabName === 'CHATS') renderMobileChatsListEngine(targetGlobalContactsArray);
                if(tabName === 'STATUS') renderStatusTab();
                if(tabName === 'CALLS') renderCallLogs();
            }

            // =============================================
            // 💬 CHAT LIST RENDER
            // =============================================
            function renderMobileChatsListEngine(arr) {
                const listTarget = document.getElementById("dynamicChatsThreadListTarget");
                if(!listTarget) return;
                listTarget.innerHTML = "";

                arr.forEach((item, globalIndex) => {
                    const lastMsg = item.stream.length > 0 ? item.stream[item.stream.length-1] : null;
                    const lastText = lastMsg ? lastMsg.text.replace(/<[^>]+>/g,'').substring(0,40) : item.phrase;
                    const badgeMarkup = item.unreadCount > 0 ? `<span class="wa-unread-count-badge">${item.unreadCount}</span>` : "";
                    const groupBadge = item.isGroup ? `<span class="group-badge">GROUP</span>` : "";

                    listTarget.insertAdjacentHTML('beforeend', `
                        <div class="wa-list-item-row" onclick="loadActiveContactConversationOverlay(${globalIndex})">
                            <div class="wa-avatar-circle"><img src="${item.img}" onerror="this.src='https://ui-avatars.com/api/?name=${encodeURIComponent(item.name)}&background=075E54&color=fff'"></div>
                            <div class="wa-item-meta-block">
                                <div class="wa-meta-top-line">
                                    <h6 class="wa-item-title">${item.name} ${groupBadge}</h6>
                                    <span class="wa-item-time-stamp" style="${item.unreadCount>0?'color:#25D366;font-weight:600;':''}">${item.time}</span>
                                </div>
                                <div class="wa-meta-bottom-line">
                                    <p class="wa-item-subtext">${lastText || item.phrase}</p>
                                    ${badgeMarkup}
                                </div>
                            </div>
                        </div>`);
                });
            }

            // =============================================
            // 🔍 SEARCH
            // =============================================
            function toggleMainScreenSearchBar(openFlag) {
                const container = document.getElementById("mainDashboardSearchOverlayContainer");
                const input = document.getElementById("mainDashboardSearchInputField");
                if(openFlag) { container.style.display = "flex"; input.focus(); }
                else { container.style.display = "none"; input.value = ""; renderMobileChatsListEngine(targetGlobalContactsArray); }
            }
            function executeMainSearchFilterPipeline(q) {
                renderMobileChatsListEngine(
                    targetGlobalContactsArray.filter(c =>
                        c.name.toLowerCase().includes(q.toLowerCase()) ||
                        c.phrase.toLowerCase().includes(q.toLowerCase())
                    )
                );
            }

            // =============================================
            // 💬 OPEN CHAT WINDOW
            // =============================================
            function loadActiveContactConversationOverlay(contactIndex) {
                compiledActiveContactIndexId = contactIndex;
                isChatWindowOpen = true;
                const contact = targetGlobalContactsArray[contactIndex];
                contact.unreadCount = 0;

                document.getElementById("targetOverlayHeaderTitle").innerText = contact.name;
                document.getElementById("targetOverlayHeaderPic").src = contact.img;
                document.getElementById("chatInputFieldElement").value = "";
                toggleInputActionButtonState("");
                clearActiveTypingTimeouts();

                const statusLabel = document.getElementById("targetOverlayHeaderStatusLabel");
                statusLabel.innerText = contact.isGroup ? `${(contact.members||[]).length+1} participants` : "online";
                statusLabel.style.color = "#ffffff";

                rebuildCurrentChatHistoryCanvasWall();
                document.getElementById("activeChatViewOverlayWindow").classList.add("open");
                renderMobileChatsListEngine(targetGlobalContactsArray);
            }

            function dismissChatConversationOverlay() {
                clearActiveTypingTimeouts();
                isChatWindowOpen = false;
                document.getElementById("activeChatViewOverlayWindow").classList.remove("open");
                document.getElementById("appEmojiTrayContainer").style.display = "none";
                document.getElementById("hiddenNativeAttachmentInputChannel").value = "";
                renderMobileChatsListEngine(targetGlobalContactsArray);
            }

            function clearActiveTypingTimeouts() {
                if(typingSimulatorTimeoutObject) { clearTimeout(typingSimulatorTimeoutObject); typingSimulatorTimeoutObject = null; }
                if(replySimulatorTimeoutObject) { clearTimeout(replySimulatorTimeoutObject); replySimulatorTimeoutObject = null; }
            }

            // =============================================
            // 🖼️ RENDER CHAT MESSAGES
            // =============================================
            function rebuildCurrentChatHistoryCanvasWall() {
                const container = document.getElementById("overlayChatMessagesScrollArea");
                container.innerHTML = `<div class="wa-encryption-alert-box">🔒 Messages and calls are end-to-end encrypted.</div>`;

                const stream = targetGlobalContactsArray[compiledActiveContactIndexId].stream;
                const isGroup = targetGlobalContactsArray[compiledActiveContactIndexId].isGroup;

                stream.forEach((node, idx) => {
                    let tickMarkup = "";
                    if(node.isMe) {
                        if(node.tickState===1) tickMarkup = `<i class="bi bi-check wa-msg-tick-icon"></i>`;
                        else if(node.tickState===2) tickMarkup = `<i class="bi bi-check-all wa-msg-tick-icon"></i>`;
                        else if(node.tickState===3) tickMarkup = `<i class="bi bi-check-all wa-msg-tick-icon blue-tick"></i>`;
                    }
                    const starMark = node.isStarred ? `<i class="bi bi-star-fill wa-msg-star-indicator"></i>` : "";
                    const senderName = (!node.isMe && isGroup && node.sender) ? `<div class="wa-msg-sender-name">${node.sender}</div>` : "";

                    container.insertAdjacentHTML('beforeend', `
                        <div class="wa-msg-bubble ${node.isMe?'wa-msg-outgoing':'wa-msg-incoming'}" onclick="triggerMessageActionPopDropdown(event,${idx})">
                            ${senderName}
                            <div>${node.text}</div>
                            <div class="wa-msg-meta-row">
                                ${starMark}
                                <span class="wa-msg-timestamp">${node.time}</span>
                                ${tickMarkup}
                            </div>
                            <div style="clear:both;"></div>
                        </div>`);
                });
                container.scrollTop = container.scrollHeight;
            }

            // =============================================
            // ✍️ SEND MESSAGE
            // =============================================
            function toggleInputActionButtonState(val) {
                const icon = document.getElementById("footerActionGlyphIcon");
                icon.className = val.trim().length > 0 ? "bi bi-send-fill" : "bi bi-mic-fill";
            }

            function handleFooterActionTriggerClick() {
                const input = document.getElementById("chatInputFieldElement");
                if(input.value.trim().length > 0) executeOutputMessagePipeline();
                else toggleVoiceMessageRecordingSession();
            }

            function executeOutputMessagePipeline() {
                const inputField = document.getElementById("chatInputFieldElement");
                const payload = inputField.value.trim();
                if(!payload) return;

                const stamp = now();
                const stream = targetGlobalContactsArray[compiledActiveContactIndexId].stream;
                const idx = stream.length;
                const contact = targetGlobalContactsArray[compiledActiveContactIndexId];

                stream.push({ text: payload, time: stamp, isMe: true, tickState: 1, isStarred: false, sender:"You" });
                rebuildCurrentChatHistoryCanvasWall();
                inputField.value = "";
                toggleInputActionButtonState("");
                clearActiveTypingTimeouts();

                // Update chat list preview
                contact.phrase = payload.substring(0,40);
                contact.time = stamp;

                // Real-time broadcast to other tabs
                if(bc) bc.postMessage({ type:'new_message', contactId: contact.id, msg: { text: payload, time: stamp, isMe: true, tickState:1, isStarred:false, sender:"You" } });

                // Tick upgrades
                setTimeout(() => { if(stream[idx]) { stream[idx].tickState=2; rebuildCurrentChatHistoryCanvasWall(); } }, 800);
                setTimeout(() => {
                    if(stream[idx]) { stream[idx].tickState=3; rebuildCurrentChatHistoryCanvasWall(); }
                    triggerControlledSingleResponse();
                }, 1800);
            }

            // =============================================
            // 🤖 AUTO REPLY SIMULATION
            // =============================================
            const replyPools = {
                default: ["Perfect! Mujhe file parameters mil gaye.", "Okay, looks good 👍", "Ji bilkul, sahi hai!", "Acha theek hai.", "Samajh gaya, thanks!", "Haan bhai, kar deta hoon.", "Sure, no problem!", "Kal baat karte hain. Okay? 🙂"],
                group: ["Sabko pata hai? 🤔", "Main aa raha hoon!", "Time change ho gaya kya?", "Okay sab ko inform kar dena.", "👍", "Noted!", "Kal milte hain sab."]
            };

            function triggerControlledSingleResponse() {
                const statusLabel = document.getElementById("targetOverlayHeaderStatusLabel");
                const captureIdx = compiledActiveContactIndexId;
                const contact = targetGlobalContactsArray[captureIdx];
                const pool = contact.isGroup ? replyPools.group : replyPools.default;

                typingSimulatorTimeoutObject = setTimeout(() => {
                    if(isChatWindowOpen && compiledActiveContactIndexId === captureIdx) {
                        statusLabel.innerText = contact.isGroup ? `${contact.members[Math.floor(Math.random()*contact.members.length)||0]} is typing...` : "typing...";
                        statusLabel.style.color = "#00e676";
                    }
                    replySimulatorTimeoutObject = setTimeout(() => {
                        if(isChatWindowOpen && compiledActiveContactIndexId === captureIdx) {
                            statusLabel.innerText = contact.isGroup ? `${(contact.members||[]).length+1} participants` : "online";
                            statusLabel.style.color = "#ffffff";
                        }
                        const replyText = pool[Math.floor(Math.random()*pool.length)];
                        const stamp = now();
                        const senderName = contact.isGroup ? (contact.members[Math.floor(Math.random()*(contact.members.length))] || "Member") : contact.name;

                        targetGlobalContactsArray[captureIdx].stream.push({ text:replyText, time:stamp, isMe:false, isStarred:false, sender:senderName });
                        targetGlobalContactsArray[captureIdx].time = stamp;
                        targetGlobalContactsArray[captureIdx].phrase = replyText.substring(0,40);

                        if(!isChatWindowOpen || compiledActiveContactIndexId !== captureIdx) {
                            targetGlobalContactsArray[captureIdx].unreadCount += 1;
                            renderMobileChatsListEngine(targetGlobalContactsArray);
                        } else {
                            rebuildCurrentChatHistoryCanvasWall();
                            renderMobileChatsListEngine(targetGlobalContactsArray);
                        }
                    }, 2200);
                }, 900);
            }

            // =============================================
            // ⭐ STAR MESSAGES
            // =============================================
            function triggerMessageActionPopDropdown(event, msgIdx) {
                event.stopPropagation();
                activeTrackedMessageTargetIndex = msgIdx;
                const drop = document.getElementById("messageContextStarDropdown");
                const btn = document.getElementById("starActionDropdownTextBtn");
                const msg = targetGlobalContactsArray[compiledActiveContactIndexId].stream[msgIdx];
                btn.innerHTML = msg.isStarred
                    ? `<i class="bi bi-star text-secondary"></i> Unstar`
                    : `<i class="bi bi-star-fill text-warning"></i> Star`;
                const rect = event.currentTarget.getBoundingClientRect();
                const appRect = document.getElementById('mainApp').getBoundingClientRect();
                drop.style.top = (rect.top - appRect.top + 20)+'px';
                drop.style.left = (event.isMe ? '60px' : '160px');
                drop.style.display = "block";
            }
            function executeToggleMessageStarTarget() {
                if(activeTrackedMessageTargetIndex===null) return;
                const msg = targetGlobalContactsArray[compiledActiveContactIndexId].stream[activeTrackedMessageTargetIndex];
                msg.isStarred = !msg.isStarred;
                rebuildCurrentChatHistoryCanvasWall();
                document.getElementById("messageContextStarDropdown").style.display = "none";
                showToast(msg.isStarred ? "Message starred ⭐" : "Star removed");
