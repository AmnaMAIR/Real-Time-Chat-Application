@{
    ViewData["Title"] = "Dashboard - WhatsApp Web";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WhatsApp Web</title>
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
            /* CSS VARIABLES FOR THEME SWITCHING */
            :root[data-theme="light"] {
                --bg-main: #fff;
                --bg-page: #f0f2f5;
                --bg-sidebar-header: #f0f2f5;
                --bg-chat-header: #f0f2f5;
                --bg-chat-footer: #f0f2f5;
                --bg-chat-area: #efeae2;
                --bg-search-input: #f0f2f5;
                --bg-chat-hover: #f5f6f6;
                --bg-chat-active: #eae6df;
                --bg-welcome: #f8f9fa;
                --text-primary: #111b21;
                --text-secondary: #54656f;
                --text-muted: #667781;
                --border-color: #e9edef;
                --bubble-incoming: #fff;
                --bubble-outgoing: #d9fdd3;
                --wallpaper-opacity: 0.08;
                --tick-color: #53bdeb;
                --green-badge: #00a884;
                --modal-bg: rgba(0,0,0,0.5);
            }

            :root[data-theme="dark"] {
                --bg-main: #111b21;
                --bg-page: #0b141a;
                --bg-sidebar-header: #202c33;
                --bg-chat-header: #202c33;
                --bg-chat-footer: #202c33;
                --bg-chat-area: #0b141a;
                --bg-search-input: #202c33;
                --bg-chat-hover: #222e35;
                --bg-chat-active: #2a3942;
                --bg-welcome: #222e35;
                --text-primary: #e9edef;
                --text-secondary: #aebac1;
                --text-muted: #8696a0;
                --border-color: #222e35;
                --bubble-incoming: #202c33;
                --bubble-outgoing: #005c4b;
                --wallpaper-opacity: 0.4;
                --tick-color: #53bdeb;
                --green-badge: #00a884;
                --modal-bg: rgba(0,0,0,0.7);
            }

            body, html {
                margin: 0;
                padding: 0;
                height: 100%;
                font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
                background-color: var(--bg-page);
                color: var(--text-primary);
                overflow: hidden;
                transition: background-color 0.3s ease;
            }

            .dashboard-container {
                display: flex;
                width: 100vw;
                height: 100vh;
                background-color: var(--bg-main);
                display: none; /* Hide desktop layout */
            }

            /* Sidebar Layout */
            .sidebar {
                width: 30%;
                min-width: 340px;
                max-width: 420px;
                height: 100%;
                border-right: 1px solid var(--border-color);
                display: flex;
                flex-direction: column;
                background-color: var(--bg-main);
            }

            .sidebar-header {
                height: 60px;
                background-color: var(--bg-sidebar-header);
                display: flex;
                justify-content: space-between;
                align-items: center;
                padding: 0 16px;
                box-sizing: border-box;
            }

            .user-profile {
                display: flex;
                align-items: center;
                gap: 10px;
            }

            .nav-avatar {
                width: 40px;
                height: 40px;
                border-radius: 50%;
                object-fit: cover;
            }

            .header-actions {
                display: flex;
                gap: 18px;
                color: var(--text-secondary);
                font-size: 18px;
                align-items: center;
            }

                .header-actions i {
                    cursor: pointer;
                }

                    .header-actions i:hover {
                        color: var(--green-badge);
                    }

            /* Search Bar Box */
            .search-box-container {
                padding: 8px 12px;
                background-color: var(--bg-main);
                border-bottom: 1px solid var(--border-color);
            }

            .search-input-wrapper {
                background-color: var(--bg-search-input);
                border-radius: 8px;
                display: flex;
                align-items: center;
                padding: 0 12px;
                gap: 12px;
            }

                .search-input-wrapper i {
                    color: var(--text-muted);
                    font-size: 14px;
                }

            .search-input {
                width: 100%;
                border: none;
                background: transparent;
                padding: 8px 0;
                font-size: 14px;
                color: var(--text-primary);
            }

                .search-input:focus {
                    outline: none;
                }

            /* Chat List Area */
            .chat-list {
                flex: 1;
                overflow-y: auto;
                background-color: var(--bg-main);
            }

            .chat-item {
                display: flex;
                align-items: center;
                padding: 12px 16px;
                gap: 12px;
                cursor: pointer;
                border-bottom: 1px solid var(--border-color);
                position: relative;
            }

                .chat-item:hover {
                    background-color: var(--bg-chat-hover);
                }

                .chat-item.active {
                    background-color: var(--bg-chat-active);
                }

            .chat-avatar {
                width: 49px;
                height: 49px;
                border-radius: 50%;
                object-fit: cover;
            }

            .chat-info {
                flex: 1;
                display: flex;
                flex-direction: column;
                gap: 4px;
            }

            .chat-row-top {
                display: flex;
                justify-content: space-between;
                align-items: center;
            }

            .friend-name {
                font-size: 16px;
                font-weight: 500;
                color: var(--text-primary);
                margin: 0;
            }

            .chat-time {
                font-size: 12px;
                color: var(--text-muted);
            }

                .chat-time.unread-time {
                    color: var(--green-badge);
                    font-weight: 600;
                }

            .chat-row-bottom {
                display: flex;
                justify-content: space-between;
                align-items: center;
            }

            .last-message {
                font-size: 14px;
                color: var(--text-muted);
                margin: 0;
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
                max-width: 200px;
                display: flex;
                align-items: center;
                gap: 3px;
            }

            .unread-badge {
                background-color: var(--green-badge);
                color: #fff;
                font-size: 12px;
                font-weight: 600;
                min-width: 20px;
                height: 20px;
                border-radius: 50%;
                display: flex;
                justify-content: center;
                align-items: center;
                padding: 2px;
                box-sizing: border-box;
            }

            /* Right Side Container */
            .right-container {
                flex: 1;
                height: 100%;
                position: relative;
            }

            /* Welcome Default Screen */
            .welcome-screen {
                position: absolute;
                width: 100%;
                height: 100%;
                background-color: var(--bg-welcome);
                display: flex;
                justify-content: center;
                align-items: center;
                border-bottom: 6px solid #00a884;
                box-sizing: border-box;
                z-index: 5;
            }

            .welcome-content {
                text-align: center;
                max-width: 500px;
                padding: 20px;
            }

            .whatsapp-landing-logo {
                font-size: 80px;
                color: var(--text-muted);
                opacity: 0.6;
                display: inline-block;
                margin-bottom: 15px;
            }

            .welcome-screen h1 {
                font-size: 32px;
                font-weight: 300;
                color: var(--text-primary);
                margin: 10px 0;
            }

            .welcome-screen p {
                font-size: 14px;
                color: var(--text-muted);
                line-height: 20px;
            }

            .encryption-note {
                margin-top: 40px !important;
                font-size: 13px !important;
                color: var(--text-muted) !important;
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 5px;
            }

            /* ACTIVE CHAT PANEL STYLING */
            .chat-window-panel {
                position: absolute;
                width: 100%;
                height: 100%;
                display: flex;
                flex-direction: column;
                background-color: var(--bg-chat-area);
                z-index: 1;
            }

            /* Chat Window Header */
            .chat-header {
                height: 60px;
                background-color: var(--bg-chat-header);
                display: flex;
                justify-content: space-between;
                align-items: center;
                padding: 0 16px;
                box-sizing: border-box;
                border-bottom: 1px solid var(--border-color);
            }

            .active-friend-info {
                display: flex;
                align-items: center;
                gap: 12px;
            }

            .active-chat-avatar {
                width: 40px;
                height: 40px;
                border-radius: 50%;
                object-fit: cover;
            }

            .active-friend-name {
                font-size: 16px;
                font-weight: 500;
                color: var(--text-primary);
                margin: 0;
            }

            .active-friend-status {
                font-size: 12px;
                color: var(--text-muted);
                margin: 0;
                transition: color 0.2s;
            }

                .active-friend-status.typing-color {
                    color: var(--green-badge);
                    font-weight: 500;
                }

            /* Message Box Area */
            .messages-area {
                flex: 1;
                overflow-y: auto;
                padding: 20px 30px;
                position: relative;
            }

                .messages-area::before {
                    content: "";
                    position: absolute;
                    top: 0;
                    left: 0;
                    width: 100%;
                    height: 100%;
                    background-image: url('https://user-images.githubusercontent.com/15075759/28719144-86dc0f70-73b1-11e7-911d-60d70fcded21.png');
                    background-repeat: repeat;
                    opacity: var(--wallpaper-opacity);
                    z-index: 0;
                    pointer-events: none;
                }

            /* Chat Bubbles Layout */
            .message-bubble {
                max-width: 65%;
                padding: 8px 12px;
                border-radius: 7.5px;
                font-size: 14.2px;
                color: var(--text-primary);
                margin-bottom: 10px;
                line-height: 19px;
                position: relative;
                box-shadow: 0 1px 0.5px rgba(0,0,0,0.13);
                z-index: 1;
            }

                .message-bubble.incoming {
                    background-color: var(--bubble-incoming);
                    align-self: flex-start;
                    float: left;
                    clear: both;
                }

                .message-bubble.outgoing {
                    background-color: var(--bubble-outgoing);
                    align-self: flex-end;
                    float: right;
                    clear: both;
                }

            .msg-time {
                font-size: 11px;
                color: var(--text-muted);
                float: right;
                margin-top: 4px;
                margin-left: 8px;
                display: flex;
                align-items: center;
                gap: 3px;
            }

            .bi-check2-all {
                color: var(--tick-color);
                font-size: 15px;
            }

            /* Bottom Typing Input Strip Bar */
            .chat-footer {
                height: 62px;
                background-color: var(--bg-chat-footer);
                display: flex;
                align-items: center;
                padding: 5px 16px;
                gap: 15px;
                box-sizing: border-box;
                border-top: 1px solid var(--border-color);
                position: relative;
            }

                .chat-footer i {
                    font-size: 24px;
                    color: var(--text-secondary);
                    cursor: pointer;
                }

            .message-input-box {
                flex: 1;
                background-color: var(--bg-main);
                border: none;
                padding: 10px 15px;
                border-radius: 8px;
                font-size: 15px;
                color: var(--text-primary);
                box-sizing: border-box;
            }

                .message-input-box:focus {
                    outline: none;
                }

            /* REALISTIC POPUPS MECHANISM */
            .custom-modal {
                position: fixed;
                top: 0;
                left: 0;
                width: 100vw;
                height: 100vh;
                background-color: var(--modal-bg);
                display: flex;
                justify-content: center;
                align-items: center;
                z-index: 999;
                visibility: hidden;
                opacity: 0;
                transition: all 0.3s ease;
            }

                .custom-modal.show {
                    visibility: visible;
                    opacity: 1;
                }

            .status-box {
                background-color: var(--bg-main);
                width: 400px;
                border-radius: 12px;
                padding: 20px;
                box-shadow: 0 4px 20px rgba(0,0,0,0.3);
                border: 1px solid var(--border-color);
            }

            .status-header {
                display: flex;
                justify-content: space-between;
                align-items: center;
                border-bottom: 1px solid var(--border-color);
                padding-bottom: 10px;
                margin-bottom: 15px;
            }

            .status-item {
                display: flex;
                align-items: center;
                gap: 12px;
                padding: 10px 5px;
                border-bottom: 1px solid var(--border-color);
            }

            .status-avatar-ring {
                width: 45px;
                height: 45px;
                border-radius: 50%;
                border: 2.5px solid var(--green-badge);
                padding: 1.5px;
                object-fit: cover;
            }

            /* CALL OVERLAY PANEL SCREEN */
            .calling-overlay {
                background: linear-gradient(135deg, #0b141a 0%, #111b21 100%);
                color: #fff;
                text-align: center;
                padding: 40px;
                border-radius: 16px;
                box-shadow: 0 8px 30px rgba(0,0,0,0.5);
                width: 320px;
            }

            .calling-avatar {
                width: 100px;
                height: 100px;
                border-radius: 50%;
                object-fit: cover;
                margin-bottom: 15px;
                border: 3px solid #00a884;
                animation: pulse-ring 1.5s infinite;
            }

            @@keyframes pulse-ring {
                0% {
                    box-shadow: 0 0 0 0 rgba(0, 168, 132, 0.4);
                }

                70% {
                    box-shadow: 0 0 0 15px rgba(0, 168, 132, 0);
                }

                100% {
                    box-shadow: 0 0 0 0 rgba(0, 168, 132, 0);
                }
            }

            .call-btn-hangup {
                background-color: #ea0038;
                color: white;
                border: none;
                width: 50px;
                height: 50px;
                border-radius: 50%;
                font-size: 20px;
                cursor: pointer;
                margin-top: 30px;
                transition: transform 0.2s;
            }

            /* NEW: ATTACHMENT MENU POPOVER */
            .attach-popover {
                position: absolute;
                bottom: 75px;
                left: 50px;
                background-color: transparent;
                display: flex;
                flex-direction: column;
                gap: 12px;
                visibility: hidden;
                opacity: 0;
                transform: translateY(20px);
                transition: all 0.25s cubic-bezier(0.175, 0.885, 0.32, 1.275);
                z-index: 10;
            }

                .attach-popover.show {
                    visibility: visible;
                    opacity: 1;
                    transform: translateY(0);
                }

            .attach-btn {
                width: 45px;
                height: 45px;
                border-radius: 50%;
                display: flex;
                justify-content: center;
                align-items: center;
                color: white;
                font-size: 18px;
                box-shadow: 0 3px 10px rgba(0,0,0,0.2);
                cursor: pointer;
                transition: transform 0.2s;
            }

                .attach-btn:hover {
                    transform: scale(1.1);
                }

            .attach-doc {
                background-color: #7f66ff;
            }

            .attach-camera {
                background-color: #ff4681;
            }

            .attach-gallery {
                background-color: #007bfc;
            }

            .attach-audio {
                background-color: #fe9e09;
            }
    </style>
</head>
<body>

    <div class="dashboard-container">

        <!-- Left Sidebar Component -->
        <div class="sidebar">
            <!-- Sidebar Top Navbar -->
            <div class="sidebar-header">
                <div class="user-profile">
                    <img src="https://cdn-icons-png.flaticon.com/512/149/149071.png" alt="My Profile Picture" class="nav-avatar" />
                    <span class="user-name">Amna</span>
                </div>
                <div class="header-actions">
                    <i class="bi bi-circle-dashed" title="Status Updates" onclick="openStatusModal()"></i>
                    <i class="bi bi-moon-fill" id="themeToggleBtn" title="Toggle Dark/Light Mode" onclick="toggleTheme()"></i>
                    <i class="bi bi-chat-left-text-fill" title="New Chat"></i>
                    <i class="bi bi-three-dots-vertical" title="Menu"></i>
                </div>
            </div>

            <!-- Sidebar Search Bar -->
            <div class="search-box-container">
                <div class="search-input-wrapper">
                    <i class="bi bi-search"></i>
                    <input type="text" placeholder="Search or start a new chat" class="search-input" id="sidebarSearchField" oninput="filterChats()" />
                </div>
            </div>

            <!-- Conversation Item List Area -->
            <div class="chat-list" id="chatListContainer">

                <!-- Friend 1 -->
                <div class="chat-item" onclick="openChat(this, 'Ayesha (Uni)', 'https://images.unsplash.com/photo-1534528741775-53994a69daeb?w=100&auto=format&fit=crop', 'Kahan ho? Assignment kab submit karwana hai?', '11:42 AM', false)">
                    <img src="https://images.unsplash.com/photo-1534528741775-53994a69daeb?w=100&auto=format&fit=crop" class="chat-avatar" alt="Avatar" />
                    <div class="chat-info">
                        <div class="chat-row-top">
                            <h4 class="friend-name">Ayesha (Uni)</h4>
                            <span class="chat-time unread-time">11:42 AM</span>
                        </div>
                        <div class="chat-row-bottom">
                            <p class="last-message">Kahan ho? hyy?</p>
                            <span class="unread-badge">1</span>
                        </div>
                    </div>
                </div>

                <!-- Friend 2 -->
                <div class="chat-item" onclick="openChat(this, 'Zain Bhai', 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=100&auto=format&fit=crop', 'Ok Bhai, main sham ko check karta hoon.', 'Yesterday', true)">
                    <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=100&auto=format&fit=crop" class="chat-avatar" alt="Avatar" />
                    <div class="chat-info">
                        <div class="chat-row-top">
                            <h4 class="friend-name">Zain Bhai</h4>
                            <span class="chat-time">Yesterday</span>
                        </div>
                        <div class="chat-row-bottom">
                            <p class="last-message"><i class="bi bi-check2-all"></i> yup.</p>
                        </div>
                    </div>
                </div>

                <!-- Friend 3 -->
                <div class="chat-item" onclick="openChat(this, 'Mama', 'https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=100&auto=format&fit=crop', 'Ghar aate hue dahi le aana beta ❤️', 'Wednesday', false)">
                    <img src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=100&auto=format&fit=crop" class="chat-avatar" alt="Avatar" />
                    <div class="chat-info">
                        <div class="chat-row-top">
                            <h4 class="friend-name">Mama</h4>
                            <span class="chat-time unread-time">Wednesday</span>
                        </div>
                        <div class="chat-row-bottom">
                            <p class="last-message">aoa ❤️</p>
                            <span class="unread-badge">2</span>
                        </div>
                    </div>
                </div>

            </div>
        </div>

        <!-- Right Side Dynamic Container Wrapper -->
        <div class="right-container">
            <!-- Welcome Default Screen -->
            <div id="welcomeScreen" class="welcome-screen">
                <div class="welcome-content">
                    <i class="bi bi-whatsapp whatsapp-landing-logo"></i>
                    <h1>WhatsApp for Web</h1>
                    <p>Send and receive messages without keeping your phone online.</p>
                    <p class="encryption-note"><i class="bi bi-lock-fill"></i> End-to-end encrypted</p>
                </div>
            </div>

            <!-- Real Dynamic Chat Window Box -->
            <div class="chat-window-panel">
                <div class="chat-header">
                    <div class="active-friend-info">
                        <img id="activeChatImg" src="" class="active-chat-avatar" alt="User Avatar" />
                        <div>
                            <h4 id="activeChatName" class="active-friend-name">Friend Name</h4>
                            <p id="activeChatStatus" class="active-friend-status">online</p>
                        </div>
                    </div>
                    <div class="header-actions">
                        <i class="bi bi-camera-video-fill" title="Video Call" onclick="triggerCallSystem('Video')"></i>
                        <i class="bi bi-telephone-fill" title="Voice Call" onclick="triggerCallSystem('Voice')"></i>
                        <i class="bi bi-search"></i>
                        <i class="bi bi-three-dots-vertical"></i>
                    </div>
                </div>

                <div class="messages-area" id="messagesAreaContainer">
                    <div class="message-bubble incoming" id="dynamicIncomingMsg">
                        <span id="incomingMsgText">Hi!</span>
                        <span class="msg-time" id="incomingMsgTime">12:00 PM</span>
                    </div>

                    <div class="message-bubble outgoing">
                        <span>Acha main check karke batati hoon.</span>
                        <span class="msg-time">Just now <i class="bi bi-check2-all"></i></span>
                    </div>
                </div>

                <!-- CHAT FOOTER WITH POPUP ATTACHMENT MENU -->
                <div class="chat-footer">
                    <!-- Attachment Popover Layer -->
                    <div class="attach-popover" id="attachmentMenu">
                        <div class="attach-btn attach-doc" title="Document"><i class="bi bi-file-earmark-text-fill"></i></div>
                        <div class="attach-btn attach-camera" title="Camera"><i class="bi bi-camera-fill"></i></div>
                        <div class="attach-btn attach-gallery" title="Photos & Videos"><i class="bi bi-image"></i></div>
                        <div class="attach-btn attach-audio" title="Audio"><i class="bi bi-headphones"></i></div>
                    </div>

                    <i class="bi bi-emoji-smile"></i>
                    <i class="bi bi-paperclip" onclick="toggleAttachmentMenu(event)"></i>
                    <input type="text" placeholder="Type a message" class="message-input-box" id="userMessageField" autocomplete="off" onkeypress="handleMessageSend(event)" />
                    <i class="bi bi-mic" onclick="sendMessageAction()"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- POPUP MODAL: STATUS INTERFACE -->
    <div id="statusModal" class="custom-modal" onclick="closeStatusModal(event)">
        <div class="status-box" onclick="event.stopPropagation()">
            <div class="status-header">
                <h3 style="margin:0; font-size:18px;">Recent Updates</h3>
                <i class="bi bi-x-lg" style="cursor:pointer;" onclick="closeStatusModal(null)"></i>
            </div>

            <div class="status-item">
                <img src="https://images.unsplash.com/photo-1534528741775-53994a69daeb?w=100&auto=format&fit=crop" class="status-avatar-ring" />
                <div>
                    <strong style="display:block;">Ayesha (Uni)</strong>
                    <span style="font-size:12px; color:var(--text-muted);">45 minutes ago</span>
                </div>
            </div>

            <div class="status-item">
                <img src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=100&auto=format&fit=crop" class="status-avatar-ring" />
                <div>
                    <strong style="display:block;">Mama</strong>
                    <span style="font-size:12px; color:var(--text-muted);">2 hours ago</span>
                </div>
            </div>
        </div>
    </div>

    <!-- POPUP MODAL: OUTGOING CALL OVERLAY INTERFACE -->
    <div id="callingModal" class="custom-modal">
        <div class="calling-overlay">
            <img id="callingUserImg" src="" class="calling-avatar" />
            <h2 id="callingUserName" style="margin:10px 0 5px 0; font-size:22px;">Friend Name</h2>
            <p id="callingTypeLabel" style="color:#00a884; margin:0; font-size:14px; font-weight:600; letter-spacing:1px;">WHATSAPP VOICE CALL</p>
            <p style="color:#8696a0; font-size:13px; margin-top:5px;">Ringing...</p>

            <button class="call-btn-hangup" onclick="endCallAction()"><i class="bi bi-telephone-x-fill"></i></button>
        </div>
    </div>

    <script>
            // Attachment Menu Toggle Engine
            function toggleAttachmentMenu(e) {
                e.stopPropagation();
                document.getElementById('attachmentMenu').classList.toggle('show');
            }

            // Hide attachment popover on clicking anywhere else on body
            document.addEventListener('click', function() {
                document.getElementById('attachmentMenu').classList.remove('show');
            });

            // Status Story Engine
            function openStatusModal() {
                document.getElementById('statusModal').classList.add('show');
            }
            function closeStatusModal(e) {
                document.getElementById('statusModal').classList.remove('show');
            }

            // Interactive Calling Engine
            function triggerCallSystem(type) {
                let activeName = document.getElementById('activeChatName').innerText;
                let activeImg = document.getElementById('activeChatImg').src;

                document.getElementById('callingUserName').innerText = activeName;
                document.getElementById('callingUserImg').src = activeImg;
                document.getElementById('callingTypeLabel').innerText = "WHATSAPP " + type.toUpperCase() + " CALL";

                document.getElementById('callingModal').classList.add('show');
            }
            function endCallAction() {
                document.getElementById('callingModal').classList.remove('show');
            }

            // Live Search Filtering
            function filterChats() {
                let filterValue = document.getElementById('sidebarSearchField').value.toLowerCase();
                let chatItems = document.querySelectorAll('.chat-item');

                chatItems.forEach(item => {
                    let friendName = item.querySelector('.friend-name').innerText.toLowerCase();
                    if(friendName.includes(filterValue)) {
                        item.style.display = "flex";
                    } else {
                        item.style.display = "none";
                    }
                });
            }

            // Theme Toggler
            function toggleTheme() {
                const htmlElement = document.documentElement;
                const themeBtn = document.getElementById('themeToggleBtn');
                const currentTheme = htmlElement.getAttribute('data-theme');

                if (currentTheme === 'light') {
                    htmlElement.setAttribute('data-theme', 'dark');
                    themeBtn.className = 'bi bi-sun-fill';
                } else {
                    htmlElement.setAttribute('data-theme', 'light');
                    themeBtn.className = 'bi bi-moon-fill';
                }
            }

            // Enhanced Chat Opener with Typing Simulation Engine!
            function openChat(element, name, avatarUrl, lastMsg, msgTime) {
                document.getElementById('welcomeScreen').style.zIndex = "-1";
                document.getElementById('welcomeScreen').style.display = "none";

                document.getElementById('activeChatName').innerText = name;
                document.getElementById('activeChatImg').src = avatarUrl;

                document.getElementById('incomingMsgText').innerText = lastMsg;
                document.getElementById('incomingMsgTime').innerHTML = msgTime;

                // Reset and Trigger Typing Simulation Status Effect
                let statusText = document.getElementById('activeChatStatus');
                statusText.innerText = "typing...";
                statusText.classList.add('typing-color');

                // Automatically shift back to online after 2 seconds
                setTimeout(() => {
                    statusText.innerText = "online";
                    statusText.classList.remove('typing-color');
                }, 2000);

                let badge = element.querySelector('.unread-badge');
                let timeLabel = element.querySelector('.chat-time');
                if(badge) badge.remove();
                if(timeLabel) timeLabel.classList.remove('unread-time');

                var chatItems = document.querySelectorAll('.chat-item');
                chatItems.forEach(item => item.classList.remove('active'));
                element.classList.add('active');

                var scrollContainer = document.getElementById('messagesAreaContainer');
                scrollContainer.scrollTop = scrollContainer.scrollHeight;
            }

            function handleMessageSend(e) {
                if(e.key === 'Enter') {
                    sendMessageAction();
                }
            }

            function sendMessageAction() {
                var messageInput = document.getElementById('userMessageField');
                var text = messageInput.value.trim();

                if(text !== "") {
                    var messagesContainer = document.getElementById('messagesAreaContainer');
                    var newBubble = document.createElement('div');
                    newBubble.className = "message-bubble outgoing";

                    var now = new Date();
                    var hours = now.getHours();
                    var minutes = now.getMinutes();
                    var ampm = hours >= 12 ? 'PM' : 'AM';
                    hours = hours % 12;
                    hours = hours ? hours : 12;
                    minutes = minutes < 10 ? '0'+minutes : minutes;
                    var currentTimeString = hours + ':' + minutes + ' ' + ampm;

                    newBubble.innerHTML = '<span>' + text + '</span><span class="msg-time">' + currentTimeString + ' <i class="bi bi-check2-all"></i></span>';

                    messagesContainer.appendChild(newBubble);
                    messageInput.value = "";
                    messagesContainer.scrollTop = messagesContainer.scrollHeight;
                }
            }
    </script>

</body>
</html>
<!DOCTYPE
<html>
<html lang="en">
<head>
    <meta charset="UTF-8">
