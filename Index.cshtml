                                <div style="font-size:0.93rem;font-weight:500;">${s.name}</div>
                                <div style="font-size:0.75rem;color:#888;">${s.time}</div>
                            </div>
                        </div>`;
                    if(s.viewed) { viewedList.insertAdjacentHTML('beforeend', markup); hasViewed = true; }
                    else unreadSection.insertAdjacentHTML('beforeend', markup);
