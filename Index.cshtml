@section Scripts {
    <script>
        // ==========================================
        // 💾 STATE PERSISTENCE RUNTIME MEMORY
        // ==========================================
        const targetGlobalContactsArray = [
            { id: "p1", name: "Programmer", img: "https://images.unsplash.com/photo-1534528741775-53994a69daeb?w=100", phone: "+92 321 4567891", phrase: "Hi, Developer, how are you?", time: "12:15 pm", unreadCount: 0, stream: [] },
            { id: "p2", name: "Zeeshan Bro", img: "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=100", phone: "+92 333 9876543", phrase: "Assignment files forward krdo please.", time: "11:40 am", unreadCount: 0, stream: [] },
            { id: "p3", name: "Ayesha University", img: "https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=100", phone: "+92 345 5551234", phrase: "Project design is approved.", time: "Yesterday", unreadCount: 0, stream: [] },
            { id: "p4", name: "CS Lab Group 👥", img: "https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=100", phone: "Group Chat - 12 participants", phrase: "Evaluation tomorrow at 9am.", time: "Yesterday", unreadCount: 0, stream: [] }
        ];

        let compiledActiveContactIndexId = 0;
        let isChatWindowOpen = false;
        let isRecordingModeActive = false;
        let recordingTimerIntervalObject = null;
        let recordingSecondsCounter = 0;
        
        let activeCallTimerIntervalObject = null;
        let callSecondsCounter = 0;
        
        let typingSimulatorTimeoutObject = null;
        let replySimulatorTimeoutObject = null;
        
        let audioContextEngineReference = null;
        let cameraStreamObjectReference = null;
        let callingStreamObjectReference = null;

        // Context trackers for active target message bubble operation
        let activeTrackedMessageTargetIndex = null;

        document.addEventListener("DOMContentLoaded", function() {
            targetGlobalContactsArray[0].stream = [
                { text: "Hi, Developer, How are you?", time: "12:15 pm", isMe: false, isStarred: false },
                { text: "Hi, Programmer, I am fine and well.", time: "12:16 pm", isMe: true, tickState: 3, isStarred: false }
            ];
            targetGlobalContactsArray[1].stream = [{ text: "Assalam o Alaikum bro, free ho?", time: "10:00 am", isMe: false, isStarred: false }];
            targetGlobalContactsArray[2].stream = [{ text: "Please share UI submission link details.", time: "Yesterday", isMe: false, isStarred: false }];
            targetGlobalContactsArray[3].stream = [{ text: "Lab tasks evaluation has been initiated inside room 403.", time: "Yesterday", isMe: false, isStarred: false }];

            renderMobileChatsListEngine(targetGlobalContactsArray);

            window.addEventListener('click', function(e) {
                const privateDrop = document.getElementById("privateChatContextDropdown");
                const mainDrop = document.getElementById("mainDashboardContextDropdown");
                const starDrop = document.getElementById("messageContextStarDropdown");
                
                if (privateDrop && !e.target.matches('.bi-three-dots-vertical')) privateDrop.style.display = 'none';
                if (mainDrop && !e.target.matches('.bi-three-dots-vertical')) mainDrop.style.display = 'none';
                if (starDrop) starDrop.style.display = 'none';
            });
        });

        // ==========================================
        // 🔍 MAIN SCREEN SEARCH & RENDER PIPELINES
        // ==========================================
        function renderMobileChatsListEngine(datasourceArray) {
            const listTarget = document.getElementById("dynamicChatsThreadListTarget");
            listTarget.innerHTML = "";
            
            datasourceArray.forEach((item) => {
                const globalIndex = targetGlobalContactsArray.findIndex(x => x.id === item.id);
                
                let currentLastPhraseText = item.phrase;
                if(item.stream.length > 0) {
                    let lastNode = item.stream[item.stream.length - 1];
                    if (lastNode.text.includes("<img")) currentLastPhraseText = "📷 Photo Attachment";
                    else if (lastNode.text.includes("audio-player")) currentLastPhraseText = "🎵 Voice Message File";
                    else if (lastNode.text.includes("bi-file-earmark")) currentLastPhraseText = "📄 Document File Packet";
                    else currentLastPhraseText = lastNode.text;
                }

                const badgeMarkup = (item.unreadCount > 0) ? `<span class="wa-unread-count-badge">${item.unreadCount}</span>` : "";

                const markupNodeRow = `
                    <div class="wa-list-item-row" onclick="loadActiveContactConversationOverlay(${globalIndex})">
                        <div class="wa-avatar-circle"><img src="${item.img}"></div>
                        <div class="wa-item-meta-block">
                            <div class="wa-meta-top-line">
                                <h6 class="wa-item-title">${item.name}</h6>
                                <span class="wa-item-time-stamp" style="${item.unreadCount > 0 ? 'color:#25D366; font-weight:bold;' : ''}">${item.time}</span>
                            </div>
                            <div class="wa-meta-bottom-line">
                                <p class="wa-item-subtext">${currentLastPhraseText}</p>
                                ${badgeMarkup}
                            </div>
                        </div>
                    </div>`;
                listTarget.insertAdjacentHTML('beforeend', markupNodeRow);
            });
        }

        function toggleMainScreenSearchBar(openFlag) {
            const container = document.getElementById("mainDashboardSearchOverlayContainer");
            const inputField = document.getElementById("mainDashboardSearchInputField");
            if(openFlag) {
                container.style.display = "flex";
                inputField.focus();
            } else {
                container.style.display = "none";
                inputField.value = "";
                renderMobileChatsListEngine(targetGlobalContactsArray);
            }
        }

        function executeMainSearchFilterPipeline(searchQueryString) {
            const filtered = targetGlobalContactsArray.filter(contact => 
                contact.name.toLowerCase().includes(searchQueryString.toLowerCase()) ||
                contact.phrase.toLowerCase().includes(searchQueryString.toLowerCase())
            );
            renderMobileChatsListEngine(filtered);
        }

        function toggleMainDashboardDropdownMenu(event) {
            event.stopPropagation();
            const el = document.getElementById("mainDashboardContextDropdown");
            el.style.display = (el.style.display === "block") ? "none" : "block";
        }

        // ==========================================
        // 💬 CONVERSATION VIEW CONTROLLERS (SAFE & UNTOUCHED)
        // ==========================================
        function loadActiveContactConversationOverlay(contactIndex) {
            compiledActiveContactIndexId = contactIndex;
            isChatWindowOpen = true;
            const targetContactNode = targetGlobalContactsArray[contactIndex];

            targetContactNode.unreadCount = 0;

            document.getElementById("targetOverlayHeaderTitle").innerText = targetContactNode.name;
            document.getElementById("targetOverlayHeaderPic").src = targetContactNode.img;
            document.getElementById("chatInputFieldElement").value = "";
            toggleInputActionButtonState("");

            clearActiveTypingTimeouts();

            document.getElementById("targetOverlayHeaderStatusLabel").innerText = "online";
            document.getElementById("targetOverlayHeaderStatusLabel").style.color = "#ffffff";
            
            rebuildCurrentChatHistoryCanvasWall();
            document.getElementById("activeChatViewOverlayWindow").classList.add("open");
        }

        function clearActiveTypingTimeouts() {
            if(typingSimulatorTimeoutObject) { clearTimeout(typingSimulatorTimeoutObject); typingSimulatorTimeoutObject = null; }
            if(replySimulatorTimeoutObject) { clearTimeout(replySimulatorTimeoutObject); replySimulatorTimeoutObject = null; }
        }

        function rebuildCurrentChatHistoryCanvasWall() {
            const container = document.getElementById("overlayChatMessagesScrollArea");
            container.innerHTML = `
                <div class="wa-encryption-alert-box">
                    Messages and calls are end-to-end encrypted. No one outside of this chat can read or listen.
                </div>`;

            const currentActiveStream = targetGlobalContactsArray[compiledActiveContactIndexId].stream;
            currentActiveStream.forEach((node, idx) => {
                let tickMarkup = "";
                if(node.isMe) {
                    if(node.tickState === 1) tickMarkup = `<i class="bi bi-check wa-msg-tick-icon"></i>`;
                    else if(node.tickState === 2) tickMarkup = `<i class="bi bi-check-all wa-msg-tick-icon"></i>`;
                    else if(node.tickState === 3) tickMarkup = `<i class="bi bi-check-all wa-msg-tick-icon blue-tick"></i>`;
                }

                const starIconMarkup = node.isStarred ? `<i class="bi bi-star-fill wa-msg-star-indicator"></i>` : "";

                // Click action bound on bubble context wrapper for interactive star tracking triggers
                const elementMarkup = `
                    <div class="wa-msg-bubble ${node.isMe ? 'wa-msg-outgoing' : 'wa-msg-incoming'}" onclick="triggerMessageActionPopDropdown(event, ${idx})">
                        <div>${node.text}</div>
                        <div class="wa-msg-meta-row">
                            ${starIconMarkup}
                            <span class="wa-msg-timestamp">${node.time}</span>
                            ${tickMarkup}
                        </div>
                        <div style="clear:both;"></div>
                    </div>`;
                container.insertAdjacentHTML('beforeend', elementMarkup);
            });
            container.scrollTop = container.scrollHeight;
        }

        function dismissChatConversationOverlay() {
            clearActiveTypingTimeouts();
            isChatWindowOpen = false;
            document.getElementById("activeChatViewOverlayWindow").classList.remove("open");
            document.getElementById("appEmojiTrayContainer").style.display = "none";
            renderMobileChatsListEngine(targetGlobalContactsArray);
        }

        function toggleInputActionButtonState(textValueString) {
            const glyphIcon = document.getElementById("footerActionGlyphIcon");
            if (textValueString.trim().length > 0) {
                glyphIcon.className = "bi bi-send-fill text-white";
            } else {
                glyphIcon.className = "bi bi-mic-fill text-white";
            }
        }

        function handleFooterActionTriggerClick() {
            const textInput = document.getElementById("chatInputFieldElement");
            if (textInput.value.trim().length > 0) {
                executeOutputMessagePipeline();
            } else {
                toggleVoiceMessageRecordingSession();
            }
        }

        // ==========================================
        // 💬 CONTROLLED ENGINE PIPELINE RESPONSES
        // ==========================================
        function executeOutputMessagePipeline() {
            const inputField = document.getElementById("chatInputFieldElement");
            const payload = inputField.value.trim();
            if(!payload) return;

            const currentTimeStamp = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', hour12: true }).toLowerCase();
            const streamRef = targetGlobalContactsArray[compiledActiveContactIndexId].stream;
            const targetIndexPointer = streamRef.length;
            
            streamRef.push({ text: payload, time: currentTimeStamp, isMe: true, tickState: 1, isStarred: false });
            rebuildCurrentChatHistoryCanvasWall();
            
            inputField.value = "";
            toggleInputActionButtonState("");

            clearActiveTypingTimeouts();

            setTimeout(() => { if(streamRef[targetIndexPointer]) { streamRef[targetIndexPointer].tickState = 2; rebuildCurrentChatHistoryCanvasWall(); } }, 800);
            setTimeout(() => {
                if(streamRef[targetIndexPointer]) { streamRef[targetIndexPointer].tickState = 3; rebuildCurrentChatHistoryCanvasWall(); }
                triggerControlledSingleResponse();
            }, 1800);
        }

        function triggerControlledSingleResponse() {
            const statusLabel = document.getElementById("targetOverlayHeaderStatusLabel");
            const capturingTargetIndex = compiledActiveContactIndexId;

            typingSimulatorTimeoutObject = setTimeout(() => {
                if(isChatWindowOpen && compiledActiveContactIndexId === capturingTargetIndex) {
                    statusLabel.innerText = "typing...";
                    statusLabel.style.color = "#00e676"; 
                }

                replySimulatorTimeoutObject = setTimeout(() => {
                    if(isChatWindowOpen && compiledActiveContactIndexId === capturingTargetIndex) {
                        statusLabel.innerText = "online";
                        statusLabel.style.color = "#ffffff";
                    }

                    const replyPoolArray = [
                        "Perfect! Muje file parameters mil gaye hain.",
                        "Okay, looks good. Main iska deployment check krta hoon.",
                        "Ji bilkul sahi code chal rha hai.",
                        "Acha, let me evaluate this design structure."
                    ];

                    const randomReplyText = replyPoolArray[Math.floor(Math.random() * replyPoolArray.length)];
                    const stamp = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', hour12: true }).toLowerCase();
                    
                    targetGlobalContactsArray[capturingTargetIndex].stream.push({ text: randomReplyText, time: stamp, isMe: false, isStarred: false });
                    function addNewContact() {
    const name = document.getElementById('newContactName').value;
    const phone = document.getElementById('newContactPhone').value;

    if (name.trim() === "" || phone.trim() === "") {
        alert("Please enter both name and number!");
        return;
    }

    // Naya contact object
    const newContact = {
        name: name,
        phone: phone,
        img: 'https://ui-avatars.com/api/?name=' + name, // Dynamic avatar
        stream: [] // Nayi chat history
    };

    // Global array mein add karna
    targetGlobalContactsArray.push(newContact);

    // Drawer band karein
    document.getElementById('submoduleNewChatDrawer').style.display = 'none';
    
    // Inputs clear karein
    document.getElementById('newContactName').value = "";
    document.getElementById('newContactPhone').value = "";

    // Refresh UI (Yahan aapka wo function hona chahiye jo contact list ko redraw karta hai)
    // Agar aapka koi refresh function hai toh wo yahan call karein, 
    // jaise: renderContactList();
    alert("Chat added successfully!");
}
                    targetGlobalContactsArray[capturingTargetIndex].time = stamp;

                    if(!isChatWindowOpen || compiledActiveContactIndexId !== capturingTargetIndex) {
